{
  "name": "react-native-brouter",
  "version": "0.0.1",
  "description": "React native turbo module for android, to communicate with the brouter app service for offline navigation based on open data",
  "source": "./src/index.tsx",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./geojson": {
      "types": "./lib/typescript/src/geojson/index.d.ts",
      "default": "./lib/module/geojson/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-brouter-example",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build lib",
    "prepare": "bob build",
    "format": "prettier . --write",
    "release": "release-kit"
  },
  "keywords": [
    "react-native",
    "android",
    "routing",
    "navigation",
    "router",
    "BRouter",
    "gpx"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhotadhari/react-native-brouter.git"
  },
  "author": "jhotadhari <tellme@waterproof-webdesign.de> (https://github.com/jhotadhari)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jhotadhari/react-native-brouter/issues"
  },
  "homepage": "https://github.com/jhotadhari/react-native-brouter#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/compat": "^1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9",
    "@evilmartians/lefthook": "^1.5.0",
    "@jhotadhari/release-kit": "file:.yalc/@jhotadhari/release-kit",
    "@react-native-community/cli": "^20.2.0",
    "@react-native/eslint-config": "^0.86.0",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "commitlint": "^21.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "prettier-plugin-embed": "^0.5.1",
    "prettier-plugin-multiline-arrays": "^4.1.10",
    "react": "^19.2.7",
    "react-native": "^0.86.0",
    "react-native-builder-bob": "^0.43.0",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "resolutions": {
    "@react-native/jest-preset/jest-environment-node": "^30.0.0"
  },
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "@react-native/jest-preset",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "codegen",
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNBRouterSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.jhotadhari.reactnative.brouter"
    },
    "includesGeneratedCode": true
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "version": "0.49.7"
  },
  "dependencies": {
    "@types/geojson": "^7946.0.16"
  }
}
